# Supabase — accounts / auth (see docs/SUPABASE_SETUP.md).
# Copy this file to `.env` and fill in your project's values (Supabase dashboard
# → Project Settings → API). Leaving these empty keeps the app in local-only mode
# (no login gate) — exactly how it behaved before auth was added.
#
# The client key is PUBLIC by design (row-level security protects the data), so the
# EXPO_PUBLIC_ prefix — which ships it in the client bundle — is correct here.
# In newer Supabase projects this key is called the "Publishable key" (sb_publishable_…);
# in older ones it's the "anon public" key. Either goes into ANON_KEY below.
# NEVER put the "Secret key" (sb_secret_… / service_role) in an EXPO_PUBLIC_ var — it bypasses RLS.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# PowerSync (sync step — see docs/POWERSYNC_SETUP.md). Empty = no sync yet.
# The instance URL from your PowerSync Cloud dashboard.
EXPO_PUBLIC_POWERSYNC_URL=
