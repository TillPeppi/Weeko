{
  "expo": {
    "name": "Weeko",
    "slug": "Weeko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "weeko",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4F1E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4F1E9",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Weeko nutzt die Kamera, um Barcodes von Lebensmitteln zu scannen."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Weeko liest Schlaf- und Aktivitätsdaten (Apple Watch, Helio Ring via Apple Health), um sie in deiner Tagesübersicht anzuzeigen.",
          "background": false
        }
      ],
      "./plugins/withNoPushEntitlement"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "ios": {
      "bundleIdentifier": "com.tillpeppi.Weeko",
      "appleTeamId": "BW54MR7M6G",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50f8619a-751b-4d17-9c64-d442c176ce03"
      }
    }
  }
}
